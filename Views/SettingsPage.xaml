<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:kal_sync.ViewModels"
             xmlns:conv="clr-namespace:kal_sync.Converters"
             x:Class="kal_sync.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Profil"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <!--
    ═══════════════════════════════════════════════════════════════════
      SettingsPage · user profile form
      ViewModel: SettingsViewModel
        WeightKg, BodyFatPercent, Age, SelectedSex, SurplusPercent,
        CalculatedBmr, SexOptions, SaveCommand
    ═══════════════════════════════════════════════════════════════════
    -->

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Bg">#F7F8FA</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="SurfaceAlt">#EFF1F4</Color>
            <Color x:Key="Ink">#1A1F2A</Color>
            <Color x:Key="Muted">#6B7280</Color>
            <Color x:Key="Faint">#9AA1AC</Color>
            <Color x:Key="Hairline">#E2E5EA</Color>
            <Color x:Key="Accent">#A8D86A</Color>
            <Color x:Key="AccentInk">#3F6E1F</Color>

            <x:String x:Key="MonoFont">JetBrainsMono</x:String>
            <x:String x:Key="UiFont">Inter</x:String>

            <Style x:Key="Eyebrow" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="CharacterSpacing" Value="3" />
                <Setter Property="TextTransform" Value="Uppercase" />
                <Setter Property="TextColor" Value="{StaticResource Muted}" />
            </Style>

            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Stroke" Value="{StaticResource Hairline}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <RoundRectangle CornerRadius="14" />
                </Setter>
            </Style>

            <Style x:Key="FieldRow" TargetType="Grid">
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="ColumnDefinitions" Value="*,Auto" />
            </Style>

            <conv:DoubleToIntStringConverter x:Key="IntStr" />
            <conv:LeanBodyMassConverter      x:Key="Lbm" />
            <conv:SurplusToColorConverter    x:Key="SurplusColor" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid BackgroundColor="{StaticResource Bg}" RowDefinitions="Auto,*,Auto">

        <!-- ─────────────────────── Header ──────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Padding="20,14,20,10" Spacing="2">
            <Label Style="{StaticResource Eyebrow}" Text="Profil" />
            <Label FontFamily="{StaticResource UiFont}" FontSize="19"
                   FontAttributes="Bold" TextColor="{StaticResource Ink}"
                   Text="Einstellungen" />
        </VerticalStackLayout>

        <!-- ─────────────────────── Body ────────────────────────── -->
        <ScrollView Grid.Row="1" Padding="16,8,16,20">
            <VerticalStackLayout Spacing="16">

                <!-- BMR preview card -->
                <Border Style="{StaticResource Card}" Padding="18,18,18,16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label Style="{StaticResource Eyebrow}" Text="Katch-McArdle BMR" />
                        <HorizontalStackLayout Spacing="6">
                            <Label FontFamily="{StaticResource MonoFont}" FontSize="36"
                                   TextColor="{StaticResource Ink}"
                                   Text="{Binding CalculatedBmr, Converter={StaticResource IntStr}}" />
                            <Label FontSize="13" TextColor="{StaticResource Muted}"
                                   VerticalOptions="End" Text="kcal/Tag" Margin="0,0,0,8" />
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" Margin="0,10" />
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="6">
                                <Label Style="{StaticResource Eyebrow}" Text="LBM" />
                                <Label FontFamily="{StaticResource MonoFont}" FontSize="10"
                                       TextColor="{StaticResource Ink}"
                                       Text="{Binding ., Converter={StaticResource Lbm},
                                              StringFormat='{0:F1} kg'}" />
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" Style="{StaticResource Eyebrow}"
                                   Text="370 + 21.6 × LBM" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Body section -->
                <Label Style="{StaticResource Eyebrow}" Text="Körper" Margin="4,0,0,0" />
                <Border Style="{StaticResource Card}" Padding="0">
                    <VerticalStackLayout>
                        <!-- Weight -->
                        <Grid Style="{StaticResource FieldRow}">
                            <Label Grid.Column="0" FontSize="14" TextColor="{StaticResource Ink}"
                                   Text="Gewicht" VerticalOptions="Center" />
                            <Stepper Grid.Column="1" Minimum="30" Maximum="200" Increment="0.5"
                                     Value="{Binding WeightKg, Mode=TwoWay}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />
                        <!-- Body fat -->
                        <Grid Style="{StaticResource FieldRow}">
                            <Label Grid.Column="0" FontSize="14" TextColor="{StaticResource Ink}"
                                   Text="Körperfett" VerticalOptions="Center" />
                            <Stepper Grid.Column="1" Minimum="3" Maximum="60" Increment="0.5"
                                     Value="{Binding BodyFatPercent, Mode=TwoWay}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />
                        <!-- Age -->
                        <Grid Style="{StaticResource FieldRow}">
                            <Label Grid.Column="0" FontSize="14" TextColor="{StaticResource Ink}"
                                   Text="Alter" VerticalOptions="Center" />
                            <Stepper Grid.Column="1" Minimum="14" Maximum="99" Increment="1"
                                     Value="{Binding AgeDouble, Mode=TwoWay}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />
                        <!-- Sex -->
                        <Grid Style="{StaticResource FieldRow}">
                            <Label Grid.Column="0" FontSize="14" TextColor="{StaticResource Ink}"
                                   Text="Geschlecht" VerticalOptions="Center" />
                            <Picker Grid.Column="1"
                                    ItemsSource="{Binding SexOptions}"
                                    SelectedItem="{Binding SelectedSex, Mode=TwoWay}"
                                    WidthRequest="120" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Calorie target -->
                <Label Style="{StaticResource Eyebrow}" Text="Kalorienziel" Margin="4,0,0,0" />
                <Border Style="{StaticResource Card}" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" FontSize="14" TextColor="{StaticResource Ink}"
                                   Text="Überschuss" VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   FontFamily="{StaticResource MonoFont}" FontSize="16"
                                   TextColor="{Binding SurplusPercent,
                                               Converter={StaticResource SurplusColor},
                                               ConverterParameter=fg}"
                                   Text="{Binding SurplusPercent, StringFormat='{0:+0.0;-0.0;0.0}%'}" />
                        </Grid>
                        <Slider Minimum="-10" Maximum="15"
                                Value="{Binding SurplusPercent, Mode=TwoWay}"
                                MinimumTrackColor="{StaticResource Accent}"
                                MaximumTrackColor="{StaticResource Hairline}"
                                ThumbColor="{StaticResource AccentInk}" />
                        <Grid ColumnDefinitions="*,*,*">
                            <Label Grid.Column="0" Style="{StaticResource Eyebrow}" Text="−10%" />
                            <Label Grid.Column="1" Style="{StaticResource Eyebrow}" Text="0"
                                   HorizontalOptions="Center" />
                            <Label Grid.Column="2" Style="{StaticResource Eyebrow}" Text="+15%"
                                   HorizontalOptions="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Save button -->
                <Button Text="Speichern"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource Ink}"
                        TextColor="{StaticResource Bg}"
                        FontFamily="{StaticResource UiFont}"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="14"
                        HeightRequest="48" />

                <!-- Version / connection info -->
                <Label HorizontalOptions="Center"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10" TextColor="{StaticResource Faint}"
                       HorizontalTextAlignment="Center"
                       Text="v0.1 · backend@10.0.2.2:8000" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ─────────────────────── Tab bar ─────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*"
              BackgroundColor="{StaticResource Surface}" Padding="0,10,0,4">
            <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                <Image Source="icon_home.png" HeightRequest="20" WidthRequest="20" Opacity="0.5" />
                <Label Style="{StaticResource Eyebrow}" Text="Home" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                <Image Source="icon_cog.png" HeightRequest="20" WidthRequest="20" />
                <Label Style="{StaticResource Eyebrow}" Text="Profil"
                       TextColor="{StaticResource Ink}" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
