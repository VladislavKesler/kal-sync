<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:kal_sync.ViewModels"
             xmlns:conv="clr-namespace:kal_sync.Converters"
             xmlns:views="clr-namespace:kal_sync.Views"
             x:Class="kal_sync.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="Home"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <!--
    ═══════════════════════════════════════════════════════════════════
      HomePage · calorie dashboard
      ViewModel: HomeViewModel
        Bmr, ActiveCalories, Tdee, TargetKcal, SurplusPercent,
        SurplusLabel, TodayLabel, IsLoading, HasData, ErrorMessage,
        Activity (ActivityResponse?),
        RefreshDataCommand, PageAppearingCommand
    ═══════════════════════════════════════════════════════════════════
    -->

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Palette -->
            <Color x:Key="Bg">#F7F8FA</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="SurfaceAlt">#EFF1F4</Color>
            <Color x:Key="Ink">#1A1F2A</Color>
            <Color x:Key="Muted">#6B7280</Color>
            <Color x:Key="Hairline">#E2E5EA</Color>
            <Color x:Key="Accent">#A8D86A</Color>
            <Color x:Key="AccentInk">#3F6E1F</Color>
            <Color x:Key="Danger">#C0533A</Color>

            <!-- Typography -->
            <x:String x:Key="MonoFont">JetBrainsMono</x:String>
            <x:String x:Key="UiFont">Inter</x:String>

            <Style x:Key="Eyebrow" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="CharacterSpacing" Value="3" />
                <Setter Property="TextTransform" Value="Uppercase" />
                <Setter Property="TextColor" Value="{StaticResource Muted}" />
            </Style>

            <Style x:Key="StatValue" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="TextColor" Value="{StaticResource Ink}" />
            </Style>

            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Stroke" Value="{StaticResource Hairline}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <RoundRectangle CornerRadius="14" />
                </Setter>
            </Style>

            <!-- Converters -->
            <conv:DoubleToIntStringConverter x:Key="IntStr" />
            <conv:SurplusToColorConverter    x:Key="SurplusColor" />
            <conv:InvertedBoolConverter      x:Key="Invert" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid BackgroundColor="{StaticResource Bg}" RowDefinitions="Auto,*,Auto">

        <!-- ─────────────────────── Top bar ──────────────────────── -->
        <Grid Grid.Row="0" Padding="20,14,20,10" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Style="{StaticResource Eyebrow}" Text="kal-sync · heute" />
                <Label FontFamily="{StaticResource UiFont}"
                       FontSize="19" FontAttributes="Bold"
                       TextColor="{StaticResource Ink}"
                       Text="{Binding TodayLabel}" />
            </VerticalStackLayout>

            <Border Grid.Column="1" WidthRequest="36" HeightRequest="36"
                    Background="{StaticResource Surface}"
                    Stroke="{StaticResource Hairline}" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                <ImageButton Source="icon_refresh.png" HeightRequest="16" WidthRequest="16"
                             BackgroundColor="Transparent"
                             Command="{Binding RefreshDataCommand}" />
            </Border>
        </Grid>

        <!-- ─────────────────────── Body ─────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Empty state: shown when no data and not loading -->
            <views:EmptyStateView
                IsVisible="{Binding HasData, Converter={StaticResource Invert}}" />

            <!-- Main content: shown when HasData = true -->
            <ScrollView IsVisible="{Binding HasData}" Padding="16,8,16,20">
                <VerticalStackLayout Spacing="16">

                    <!-- ── Hero card with target ring ───────────── -->
                    <Border Style="{StaticResource Card}" Padding="16,24,16,18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="18">

                            <!-- Ring + center label stack -->
                            <Grid HeightRequest="232" HorizontalOptions="Center">
                                <GraphicsView x:Name="RingView"
                                              WidthRequest="232" HeightRequest="232">
                                    <GraphicsView.Drawable>
                                        <conv:TargetRingDrawable x:Name="RingDrawable" />
                                    </GraphicsView.Drawable>
                                </GraphicsView>
                                <VerticalStackLayout VerticalOptions="Center"
                                                     HorizontalOptions="Center" Spacing="2">
                                    <Label Style="{StaticResource Eyebrow}"
                                           Text="Tagesziel" HorizontalOptions="Center" />
                                    <Label FontFamily="{StaticResource MonoFont}"
                                           FontSize="56" TextColor="{StaticResource Ink}"
                                           HorizontalOptions="Center"
                                           Text="{Binding TargetKcal, Converter={StaticResource IntStr}}" />
                                    <Label FontSize="13" TextColor="{StaticResource Muted}"
                                           Text="kcal" HorizontalOptions="Center" />
                                    <Border Padding="8,3" Margin="0,8,0,0"
                                            HorizontalOptions="Center"
                                            Background="{Binding SurplusPercent,
                                                         Converter={StaticResource SurplusColor},
                                                         ConverterParameter=bg}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Label FontSize="11"
                                               TextColor="{Binding SurplusPercent,
                                                           Converter={StaticResource SurplusColor},
                                                           ConverterParameter=fg}"
                                               Text="{Binding SurplusLabel}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- BMR / TDEE / Aktiv strip -->
                            <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />
                            <Grid ColumnDefinitions="*,*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                    <Label Style="{StaticResource Eyebrow}" Text="BMR" HorizontalOptions="Center" />
                                    <HorizontalStackLayout Spacing="3" HorizontalOptions="Center">
                                        <Label Style="{StaticResource StatValue}" FontSize="16"
                                               Text="{Binding Bmr, Converter={StaticResource IntStr}}" />
                                        <Label FontSize="10" TextColor="{StaticResource Muted}"
                                               VerticalOptions="End" Text="kcal" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                    <Label Style="{StaticResource Eyebrow}" Text="TDEE" HorizontalOptions="Center" />
                                    <HorizontalStackLayout Spacing="3" HorizontalOptions="Center">
                                        <Label Style="{StaticResource StatValue}" FontSize="16"
                                               Text="{Binding Tdee, Converter={StaticResource IntStr}}" />
                                        <Label FontSize="10" TextColor="{StaticResource Muted}"
                                               VerticalOptions="End" Text="kcal" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                                    <Label Style="{StaticResource Eyebrow}" Text="Aktiv" HorizontalOptions="Center" />
                                    <HorizontalStackLayout Spacing="3" HorizontalOptions="Center">
                                        <Label Style="{StaticResource StatValue}" FontSize="16"
                                               Text="{Binding ActiveCalories, Converter={StaticResource IntStr}}" />
                                        <Label FontSize="10" TextColor="{StaticResource Muted}"
                                               VerticalOptions="End" Text="kcal" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Surplus/Deficit slider ───────────────── -->
                    <Label Style="{StaticResource Eyebrow}" Text="Anpassung" Margin="4,0,0,0" />
                    <Border Style="{StaticResource Card}" Padding="16,14">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Style="{StaticResource Eyebrow}" Text="Überschuss" />
                                    <Label FontSize="13" TextColor="{StaticResource Ink}" Text="Lean Bulk" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       FontFamily="{StaticResource MonoFont}" FontSize="22"
                                       TextColor="{Binding SurplusPercent,
                                                   Converter={StaticResource SurplusColor},
                                                   ConverterParameter=fg}"
                                       Text="{Binding SurplusPercent, StringFormat='{0:+0.0;-0.0;0.0}%'}" />
                            </Grid>
                            <Slider Minimum="-10" Maximum="15"
                                    Value="{Binding SurplusPercent, Mode=TwoWay}"
                                    MinimumTrackColor="{StaticResource Accent}"
                                    MaximumTrackColor="{StaticResource Hairline}"
                                    ThumbColor="{StaticResource AccentInk}" />
                            <Grid ColumnDefinitions="*,*,*">
                                <Label Grid.Column="0" Style="{StaticResource Eyebrow}" Text="−10%" />
                                <Label Grid.Column="1" Style="{StaticResource Eyebrow}" Text="0"
                                       HorizontalOptions="Center" />
                                <Label Grid.Column="2" Style="{StaticResource Eyebrow}" Text="+15%"
                                       HorizontalOptions="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Garmin activity row ──────────────────── -->
                    <Label Style="{StaticResource Eyebrow}" Text="Garmin" Margin="4,0,0,0" />
                    <Border Style="{StaticResource Card}" Padding="16,14">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" WidthRequest="32" HeightRequest="32"
                                        Background="{StaticResource SurfaceAlt}"
                                        Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                    <Image Source="icon_watch.png" HeightRequest="18" WidthRequest="18"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                    <Label FontSize="13" FontAttributes="Bold"
                                           TextColor="{StaticResource Ink}" Text="Letzte Aktivität" />
                                    <Label FontFamily="{StaticResource MonoFont}" FontSize="10"
                                           TextColor="{StaticResource Muted}"
                                           Text="{Binding Activity.ActivityDate}" />
                                </VerticalStackLayout>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />
                            <Grid ColumnDefinitions="*,*,*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Style="{StaticResource Eyebrow}" Text="Dauer" />
                                    <Label FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           TextColor="{StaticResource Ink}"
                                           Text="{Binding Activity.DurationMinutes, StringFormat='{0} min'}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Style="{StaticResource Eyebrow}" Text="Ø HR" />
                                    <Label FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           TextColor="{StaticResource Ink}"
                                           Text="{Binding Activity.AvgHr}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="3">
                                    <Label Style="{StaticResource Eyebrow}" Text="Max HR" />
                                    <Label FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           TextColor="{StaticResource Ink}"
                                           Text="{Binding Activity.MaxHr}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Spacing="3">
                                    <Label Style="{StaticResource Eyebrow}" Text="Garmin" />
                                    <Label FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           TextColor="{StaticResource Ink}"
                                           Text="{Binding Activity.GarminCalories,
                                                  Converter={StaticResource IntStr},
                                                  StringFormat='{0} kcal'}" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error label -->
                    <Label IsVisible="{Binding ErrorMessage, Converter={StaticResource Invert}}"
                           Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="12" HorizontalOptions="Center" />

                </VerticalStackLayout>
            </ScrollView>

            <!-- Loading overlay (centered on top of everything) -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource AccentInk}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>

        <!-- ─────────────────────── Bottom tab bar ───────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*"
              BackgroundColor="{StaticResource Surface}"
              Padding="0,10,0,4">
            <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                <Image Source="icon_home.png" HeightRequest="20" WidthRequest="20" />
                <Label Style="{StaticResource Eyebrow}" Text="Home"
                       TextColor="{StaticResource Ink}" FontAttributes="Bold" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                <Image Source="icon_cog.png" HeightRequest="20" WidthRequest="20" Opacity="0.5" />
                <Label Style="{StaticResource Eyebrow}" Text="Profil" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
