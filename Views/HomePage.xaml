<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="kal_sync.Views.HomePage"
             Title="kal-sync"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Loading Indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="Blue"
                Scale="1.5" />

            <!-- Error Message -->
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                FontSize="14"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullEmptyConverter}}"
                Padding="10"
                BackgroundColor="#FFE5E5" />

            <!-- Empty State (no data, not loading) -->
            <VerticalStackLayout
                Spacing="10"
                IsVisible="{Binding HasData, Converter={StaticResource InvertedBoolConverter}}"
                VerticalOptions="Center"
                HorizontalOptions="Center">

                <Label
                    Text="📊"
                    FontSize="48"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

                <Label
                    Text="Keine Daten geladen"
                    FontSize="16"
                    TextColor="Gray"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

                <Label
                    Text="Klick 'Neu laden' um Daten zu fetchen"
                    FontSize="12"
                    TextColor="LightGray"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Dashboard Cards (visible when HasData) -->
            <VerticalStackLayout IsVisible="{Binding HasData}" Spacing="16">

                <!-- Card 1: BMR (Gray) -->
                <Border Stroke="Gray" StrokeThickness="1" Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🔥 Grundumsatz (BMR)"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding Bmr, StringFormat='{0:F0} kcal'}"
                               FontAttributes="Bold"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Katch-McArdle Formel"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card 2: Aktivkalorien (Orange) -->
                <Border Stroke="Orange" StrokeThickness="1" Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2E1F0A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="⚡ Aktivkalorien"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding ActiveCalories, StringFormat='{0:F0} kcal'}"
                               FontAttributes="Bold"
                               FontSize="36"
                               TextColor="Orange"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Letzte Aktivität (Keytel-Formel)"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card 3: TDEE (Blue) -->
                <Border Stroke="#0055AA" StrokeThickness="1" Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#0A1929}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📊 Gesamtkalorienbedarf (TDEE)"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding Tdee, StringFormat='{0:F0} kcal'}"
                               FontAttributes="Bold"
                               FontSize="36"
                               TextColor="#0055AA"
                               HorizontalTextAlignment="Center" />
                        <Label Text="BMR + Aktivkalorien"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card 4: Kalorienziel (Green) -->
                <Border Stroke="Green" StrokeThickness="1" Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#F0FFF0, Dark=#1A2E1A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🎯 Kalorienziel"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding TargetKcal, StringFormat='{0:F0} kcal'}"
                               FontAttributes="Bold"
                               FontSize="36"
                               TextColor="Green"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding SurplusLabel}"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- Refresh Button -->
            <Button
                Text="🔄 Neu laden"
                Command="{Binding RefreshDataCommand}"
                BackgroundColor="Blue"
                TextColor="White"
                Padding="20"
                FontSize="16"
                CornerRadius="8"
                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
