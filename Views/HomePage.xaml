<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:kal_sync.ViewModels"
             x:Class="kal_sync.Views.HomePage"
             Title="kal-sync"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Loading Indicator -->
        <ActivityIndicator 
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="Blue"
            Scale="1.5" />

        <!-- Error Message -->
        <Label 
            Text="{Binding ErrorMessage}"
            TextColor="Red"
            FontSize="14"
            IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullEmptyConverter}}"
            Padding="10"
            BackgroundColor="#FFE5E5" />

        <!-- Main Content (when no loading) -->
        <VerticalStackLayout 
            Spacing="15"
            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
            Padding="0">

            <!-- Empty State -->
            <VerticalStackLayout 
                Spacing="10"
                IsVisible="{Binding HasActivity, Converter={StaticResource InvertedBoolConverter}}"
                VerticalOptions="Center"
                HorizontalOptions="Center">

                <Label 
                    Text="📊"
                    FontSize="48"
                    HorizontalTextAlignment="Center" />

                <Label 
                    Text="Keine Aktivität geladen"
                    FontSize="16"
                    TextColor="Gray"
                    HorizontalTextAlignment="Center" />

                <Label 
                    Text="Klick 'Neu laden' um Daten zu fetchen"
                    FontSize="12"
                    TextColor="LightGray"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Activity Content (when HasActivity = true) -->
            <VerticalStackLayout IsVisible="{Binding HasActivity}" Spacing="12">

                <!-- Activity Card (Border statt Frame) -->
                <Border Stroke="Gray" StrokeThickness="1" Padding="15" 
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}">
                    <VerticalStackLayout Spacing="10">
                        <Label 
                            Text="📋 Letzte Aktivität"
                            FontAttributes="Bold"
                            FontSize="18" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto,auto,auto" ColumnSpacing="10" RowSpacing="8">
                            <!-- Datum -->
                            <Label Text="Datum:" Grid.Row="0" Grid.Column="0" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding CurrentActivity.ActivityDate, StringFormat='{0}'}" 
                                   Grid.Row="0" Grid.Column="1" FontSize="12" FontAttributes="Bold" />

                            <!-- Dauer -->
                            <Label Text="Dauer:" Grid.Row="1" Grid.Column="0" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding CurrentActivity.DurationMinutes, StringFormat='{0} min'}" 
                                   Grid.Row="1" Grid.Column="1" FontSize="12" FontAttributes="Bold" />

                            <!-- Ø HR -->
                            <Label Text="Ø HR:" Grid.Row="2" Grid.Column="0" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding CurrentActivity.AvgHr, StringFormat='{0} bpm'}" 
                                   Grid.Row="2" Grid.Column="1" FontSize="12" FontAttributes="Bold" />

                            <!-- Max HR -->
                            <Label Text="Max HR:" Grid.Row="3" Grid.Column="0" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding CurrentActivity.MaxHr, StringFormat='{0} bpm'}" 
                                   Grid.Row="3" Grid.Column="1" FontSize="12" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Calorie Comparison Card (Border statt Frame) -->
                <Border Stroke="Green" StrokeThickness="1" Padding="15" 
                        BackgroundColor="{AppThemeBinding Light=#F0FFF0, Dark=#1A2E1A}">
                    <VerticalStackLayout Spacing="12">
                        <Label 
                            Text="⚡ Calorie-Vergleich"
                            FontAttributes="Bold"
                            FontSize="16" />

                        <!-- Calorie Values Side by Side -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Garmin" FontSize="12" TextColor="Gray" />
                                <Label 
                                    Text="{Binding CurrentActivity.GarminCalories, StringFormat='{0:F0}'}"
                                    FontAttributes="Bold"
                                    FontSize="26"
                                    TextColor="Blue" />
                                <Label Text="kcal" FontSize="11" TextColor="Gray" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Echte Kcal" FontSize="12" TextColor="Gray" />
                                <Label 
                                    Text="{Binding CurrentActivity.CalculatedCalories, StringFormat='{0:F0}'}"
                                    FontAttributes="Bold"
                                    FontSize="26"
                                    TextColor="Green" />
                                <Label Text="kcal" FontSize="11" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Difference -->
                        <BoxView Color="LightGray" HeightRequest="1" Margin="0,5,0,5" />

                        <Label 
                            Text="{Binding CurrentActivity.Difference, StringFormat='Differenz: {0:F0} kcal'}"
                            FontSize="14"
                            TextColor="Orange"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Zone Distribution Card (Border statt Frame) -->
                <Border Stroke="Orange" StrokeThickness="1" Padding="15" 
                        BackgroundColor="{AppThemeBinding Light=#FFF5E5, Dark=#2E1F0A}">
                    <VerticalStackLayout Spacing="10">
                        <Label 
                            Text="🎯 HR-Zonen Distribution"
                            FontAttributes="Bold"
                            FontSize="16" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto,auto,auto,auto" ColumnSpacing="10" RowSpacing="6">
                            <!-- Zone 1 -->
                            <Label Text="Zone 1 (99-117):" Grid.Row="0" Grid.Column="0" FontSize="12" />
                            <Label Text="{Binding CurrentActivity.Zones.Zone1Minutes, StringFormat='{0} min'}" 
                                   Grid.Row="0" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />

                            <!-- Zone 2 -->
                            <Label Text="Zone 2 (118-137):" Grid.Row="1" Grid.Column="0" FontSize="12" />
                            <Label Text="{Binding CurrentActivity.Zones.Zone2Minutes, StringFormat='{0} min'}" 
                                   Grid.Row="1" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />

                            <!-- Zone 3 -->
                            <Label Text="Zone 3 (138-157):" Grid.Row="2" Grid.Column="0" FontSize="12" />
                            <Label Text="{Binding CurrentActivity.Zones.Zone3Minutes, StringFormat='{0} min'}" 
                                   Grid.Row="2" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />

                            <!-- Zone 4 -->
                            <Label Text="Zone 4 (158-176):" Grid.Row="3" Grid.Column="0" FontSize="12" />
                            <Label Text="{Binding CurrentActivity.Zones.Zone4Minutes, StringFormat='{0} min'}" 
                                   Grid.Row="3" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />

                            <!-- Zone 5 -->
                            <Label Text="Zone 5 (177+):" Grid.Row="4" Grid.Column="0" FontSize="12" />
                            <Label Text="{Binding CurrentActivity.Zones.Zone5Minutes, StringFormat='{0} min'}" 
                                   Grid.Row="4" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>

        <!-- Spacer -->
        <BoxView HeightRequest="1" />

        <!-- Refresh Button -->
        <Button 
            Text="🔄 Neu laden"
            Command="{Binding RefreshDataCommand}"
            BackgroundColor="Blue"
            TextColor="White"
            Padding="20"
            FontSize="16"
            CornerRadius="8"
            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
    </VerticalStackLayout>
</ContentPage>